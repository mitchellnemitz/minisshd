{
  "permissions": {
    "allow": [
      "Bash(make test:*)",
      "Bash(make test-slow:*)",
      "Bash(make build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "Bash(go mod tidy:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/gofmt-on-write.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/precommit-gates.sh"
          }
        ]
      }
    ]
  }
}
